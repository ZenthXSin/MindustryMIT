# Auto detect text files and perform LF normalization
* text=auto

# Binary files — never apply EOL conversion
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.so binary
*.dll binary
*.class binary

# Shell scripts must keep LF
*.sh    text eol=lf
gradlew text eol=lf
